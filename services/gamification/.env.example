# Compose tarafindan saglanan degiskenler (dokumantasyon amacli)
ConnectionStrings__Default=Host=gamification-db;Port=5432;Database=gamification_db;Username=gamification_user;Password=CHANGE_ME
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=campaigncell
RABBITMQ_PASSWORD=CHANGE_ME
REDIS_HOST=redis
# Identity'nin /api/v1/users/experts endpoint'i icin (Core_Principles §6: Gateway atlanir,
# X-Internal-Api-Key ile korunur) - tum servislerde AYNI deger olmali.
INTERNAL_API_KEY=CHANGE_ME
IdentityService__BaseUrl=http://identity-api:8080
# GameHub (SignalR) JWT dogrulamasi icin - Identity/Campaign/Gateway ile AYNI deger olmali.
Jwt__Secret=CHANGE_ME
