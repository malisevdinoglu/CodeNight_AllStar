# CampaignCell — docker-compose ortam değişkenleri
# Kopyala: cp .env.example .env  (compose .env'i otomatik okur; .env commit'lenmez)

IDENTITY_DB_USER=identity
IDENTITY_DB_PASS=identity
CAMPAIGN_DB_USER=campaign
CAMPAIGN_DB_PASS=campaign
AI_DB_USER=ai
AI_DB_PASS=ai
GAMIFICATION_DB_USER=gamification
GAMIFICATION_DB_PASS=gamification

RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Uygulama servisleri eklendikçe: JWT_SECRET, INTERNAL_API_KEY vb. buraya gelecek
