# CampaignCell ortam degiskenleri — kopyala: cp .env.example .env
# Secrets koda gomulmez (Core_Principles §10). .env git'e girmez.

ASPNETCORE_ENVIRONMENT=Development

# Her DB'ye ayri kullanici/sifre (database-per-service, fiziksel ayrim)
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=CHANGE_ME
IDENTITY_DB_NAME=identity_db

CAMPAIGN_DB_USER=campaign_user
CAMPAIGN_DB_PASSWORD=CHANGE_ME
CAMPAIGN_DB_NAME=campaign_db

AI_DB_USER=ai_user
AI_DB_PASSWORD=CHANGE_ME
AI_DB_NAME=ai_db

GAMIFICATION_DB_USER=gamification_user
GAMIFICATION_DB_PASSWORD=CHANGE_ME
GAMIFICATION_DB_NAME=gamification_db

RABBITMQ_USER=campaigncell
RABBITMQ_PASSWORD=CHANGE_ME

# JWT (Core_Principles §6) — Gateway dogrular, Identity (Faz 4) ayni sirla imzalar.
# Issuer/Audience appsettings.json'da sabit; tek gizli deger Secret'tir.
# HS256 icin anahtar >= 256 bit (>= 32 karakter) OLMALI — kisa deger login'de 500 verir.
# Asagidaki DEV varsayilani calisir haldedir (64 hex = 256 bit); uretimde `openssl rand -hex 32` ile degistir.
JWT_SECRET=f37b9f99fc94c5c6f5935d668ca45d4923648ee865ae0e90d6f2f6e36947d3a5

# Servisler arasi sistem cagrilari icin API anahtari (Core_Principles §6)
INTERNAL_API_KEY=CHANGE_ME
